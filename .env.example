# ============================================
# TermSpark 环境变量配置
# ============================================
# 复制此文件为 .env 并按需修改：
#   cp .env.example .env
# ⚠ .env 已加入 .gitignore，不会被提交到仓库

# ─── 服务 ──────────────────────────────────
PORT=3001
UPLOADS_DIR=./uploads

# ─── 数据库 ───────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/termspark

# ─── JWT ──────────────────────────────────
# 生成随机密钥: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# ─── 邀请码（注册时使用）────────────────
INVITE_CODE=zzxx

# ─── AI 服务配置（opencode 或 omlx）───────
AI_PROVIDER=opencode

# ─── OpenCode AI（图片识别） ───────────────
# 从 https://opencode.ai 的 Go 订阅中获取
OPCODE_API_KEY=sk-your-opencode-api-key
OPCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPCODE_MODEL=mimo-v2.5

# ─── oMLX AI（图片识别，备用） ───────────
OMLX_URL=http://localhost:11434/v1
OMLX_MODEL=llava
OMLX_API_KEY=omlx-key

# ─── 初始管理员（首次运行 seed 时使用） ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
